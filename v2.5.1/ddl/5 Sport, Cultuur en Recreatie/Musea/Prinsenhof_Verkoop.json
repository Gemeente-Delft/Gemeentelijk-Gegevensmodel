{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Prinsenhof Verkoop",
  "description": "JSON Schema gegenereerd vanuit het Gemeentelijk Gegevensmodel voor diagram: Prinsenhof Verkoop",
  "$defs": {
    "BALIEVERKOOP": {
