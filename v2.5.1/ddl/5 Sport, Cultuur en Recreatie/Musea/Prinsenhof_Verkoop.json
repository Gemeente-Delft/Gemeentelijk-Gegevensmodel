      "properties": {
        "DATUMEINDEGELDIGHEID": {
          "type": "string",
          "format": "date"
        },
        "DATUMSTART": {
          "type": "string",
          "format": "date"
        },
        "GEBRUIKTOP": {
          "type": "string"
        },
        "RONDLEIDING": {
          "type": "boolean"
        }
      }
    },
    "ENTREEKAART": {
      "title": "ENTREEKAART",
