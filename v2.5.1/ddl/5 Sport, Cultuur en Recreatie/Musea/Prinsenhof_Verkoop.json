      "type": "object",
      "properties": {
        "RONDLEIDING": {
          "type": "boolean"
        }
      }
    },
    "OMZETGROEP": {
      "title": "OMZETGROEP",
      "description": "Artikelen worden gebruikt om omzet te registreren in de shop, de horeca of elders. De omzet wordt vervolgens getotaliseerd op rapportages. Om de artikelen te groeperen moet ieder artikel tot een omzetgroep behoren.",
      "type": "object",
      "properties": {
        "NAAM": {
          "type": "string"
        },
        "OMSCHRIJVING": {
          "type": "string"
        }
      }
    },
    "PRODUCT": {
      "title": "PRODUCT",
