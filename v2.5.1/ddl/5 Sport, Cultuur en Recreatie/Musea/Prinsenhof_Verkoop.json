      "type": "object",
      "properties": {
        "CODEMUSEUMJAARKAART": {
          "type": "string"
        },
        "DATUMEINDEGELDIGHEID": {
          "type": "string",
          "format": "date"
        },
        "DATUMSTART": {
          "type": "string",
          "format": "date"
        },
        "ENTREEKAART": {
          "type": "integer"
        },
        "OMSCHRIJVING": {
          "type": "string"
        },
        "PRIJS": {
          "type": "number"
        }
