      "properties": {
        "AANTAL": {
          "type": "integer"
        },
        "KANAAL": {
          "type": "string",
          "description": "Verkocht via kassa, online of ander kanaal"
        },
        "VERKOOPTIJD": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "BALIEVERKOOP_ENTREEKAART": {
      "title": "BALIEVERKOOP_ENTREEKAART",
