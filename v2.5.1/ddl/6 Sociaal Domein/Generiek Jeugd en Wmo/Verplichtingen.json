  "$defs": {
    "AOM_AANVRAAGWMOJEUGD": {
      "title": "AOM_AANVRAAGWMOJEUGD",
      "description": "*AOM_AanvraagWmoJeugd* is een objecttype in het gegevensmodel voor Wmo en Jeugd dat een **aanvraagtraject voor ondersteuning onder de Wet maatschappelijke ondersteuning (Wmo) en/of Jeugdwet** representeert.",
      "type": "object",
      "properties": {
        "CLIENTREACTIE": {
          "type": "string"
        },
        "DATUMBESCHIKKING": {
          "type": "string",
          "format": "date"
        },
        "DATUMEERSTEAFSPRAAK": {
          "type": "string",
          "format": "date",
          "description": "De datum van de eerste afspraak in het\nproces."
        },
        "DATUMEINDE": {
          "type": "string",
          "format": "date",
          "description": "De daadwerkelijke einddatum van de\ngekozen doorlooptijd. Dit is datum plan, datum beschikking, datum afsluiten proces of niet van toepassing. Deze einddatum is afhankelijk van de gekozen doorloopmethodiek"
        },
        "DATUMPLANVASTGESTELD": {
          "type": "string",
          "format": "date",
          "description": "De datum waarop het plan is vastgesteld in de melding."
        },
        "DATUMSTARTAANVRAAG": {
          "type": "string",
          "format": "date",
          "description": "Start van het proces=start vd aanvraag"
        },
